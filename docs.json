{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "RemoteAgent",
  "colors": {
    "primary": "#1B84FF",
    "light": "#60AEFF",
    "dark": "#0D5ECC"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "remoteagent.chat",
        "href": "https://remoteagent.chat"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get started free",
      "href": "https://remoteagent.chat/signup"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Overview",
            "pages": ["introduction"]
          },
          {
            "group": "Getting Started",
            "pages": [
              "getting-started/quickstart",
              "getting-started/installation",
              "getting-started/pairing"
            ]
          },
          {
            "group": "Runners",
            "pages": [
              "runners/overview",
              "runners/claude-sdk",
              "runners/claude-code",
              "runners/gemini",
              "runners/aider",
              "runners/opencode",
              "runners/openclaw",
              "runners/custom"
            ]
          },
          {
            "group": "Using the Bot",
            "pages": [
              "bot/sending-commands",
              "bot/multi-project",
              "bot/offline-alerts"
            ]
          },
          {
            "group": "Platform",
            "pages": [
              "dashboard",
              "pricing"
            ]
          },
          {
            "group": "Under the Hood",
            "pages": [
              "under-the-hood/architecture",
              "under-the-hood/services",
              "under-the-hood/security"
            ]
          },
          {
            "group": "Support",
            "pages": ["faq"]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "remoteagent.chat",
          "href": "https://remoteagent.chat",
          "icon": "house"
        },
        {
          "anchor": "Telegram bot",
          "href": "https://t.me/remoteagent_bot",
          "icon": "paper-plane"
        }
      ]
    }
  },
  "seo": {
    "indexHiddenPages": false,
    "noindex": true
  },
  "footer": {
    "socials": {
      "github": "https://github.com/ggiacomo/docs"
    }
  }
}
